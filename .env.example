# Optional for live model calls through OpenRouter.
# Without this, the app runs in guided demo mode.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_MODEL=openai/gpt-5.4-mini

# Optional attribution headers recommended by OpenRouter.
OPENROUTER_HTTP_REFERER=http://localhost:3000
OPENROUTER_APP_TITLE=Chandra

# Python API used by the Next.js server for LangGraph PDF RAG chat.
BACKEND_API_BASE_URL=http://127.0.0.1:8000
BACKEND_SHARED_SECRET=
LEARNING_PROFILE_UPDATE_SECRET=

# Firebase web app config. Enable Email/Password auth and Firestore in Firebase.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin for server-side auth, Firestore writes, and Storage uploads.
# You can use FIREBASE_SERVICE_ACCOUNT_KEY or the split client email/private key vars.
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_SERVICE_ACCOUNT_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Dedicated GCS bucket for canonical PDF originals and exact single-page page assets.
# Required in production. Uses Google Application Default Credentials/service account identity.
GCS_PDF_ASSETS_BUCKET=chandra-f6e13-pdf-page-assets

# Cloud SQL PostgreSQL stores app data and searchable PDF OCR metadata.
# DATABASE_URL is also supported; use one of these connection URLs at runtime.
# Local dev can use Cloud SQL Auth Proxy on 127.0.0.1:5432 with sslmode=disable.
# Production should use the Cloud SQL private IP/VPC path or a managed connector, never localhost.
DATABASE_URL=
CLOUD_SQL_POSTGRES_URL=
CHANDRA_CLOUD_SQL_POSTGRES_URL=
CLOUD_SQL_POSTGRES_SSL_MODE=
CLOUD_SQL_POSTGRES_POOL_MAX=
# Defaults to false. Set to 1 only for temporary legacy migration/debug sessions.
POSTGRES_FIRESTORE_FALLBACK=
# Local dev helper for npm run dev:all. Defaults to chandra-f6e13:us-central1:chandra-postgres.
CHANDRA_DEV_CLOUD_SQL_PROXY=
CLOUD_SQL_INSTANCE_CONNECTION_NAME=
CLOUD_SQL_PROXY_BIN=
CLOUD_SQL_PROXY_PORT=5432

# Vertex AI embeddings for tutor knowledge retrieval.
# GOOGLE_CLOUD_PROJECT can be omitted when FIREBASE_PROJECT_ID is the same project.
GEMINI_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us
VERTEX_EMBEDDING_MODEL=gemini-embedding-2
VERTEX_EMBEDDING_DIMENSIONS=768

# Optional if Application Default Credentials are not available.
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_APPLICATION_CREDENTIALS_JSON=
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
