# Optional for some local demo paths, required for production live tutor calls.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_MODEL=openai/gpt-5.4-mini

# Better Stack observability. Leave tokens blank locally; structured JSON logs
# still go to stdout/stderr when Better Stack is not configured.
BETTER_STACK_SOURCE_TOKEN=
BETTER_STACK_INGESTING_HOST=
BETTER_STACK_UPTIME_API_TOKEN=
BETTER_STACK_RETENTION_HEARTBEAT_URL=
BETTER_STACK_LEARNING_PROFILE_HEARTBEAT_URL=
BETTER_STACK_ENV=development

# Optional attribution headers recommended by OpenRouter.
OPENROUTER_HTTP_REFERER=http://localhost:3000
OPENROUTER_APP_TITLE=Chandra

# Python API used by the Next.js server for LangGraph PDF RAG chat.
# BACKEND_SHARED_SECRET is required anywhere the LangGraph backend accepts traffic.
BACKEND_API_BASE_URL=http://127.0.0.1:8000
BACKEND_SHARED_SECRET=
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Required in production backend so FastAPI can call Next.js internal retrieval routes.
FRONTEND_ORIGIN=http://localhost:3000
NEXT_INTERNAL_BASE_URL=http://127.0.0.1:3000
LEARNING_PROFILE_UPDATE_SECRET=
# Optional. If omitted, conversation retention can reuse LEARNING_PROFILE_UPDATE_SECRET.
CONVERSATION_RETENTION_SECRET=

# Firebase web app config. Enable Email/Password auth and Firestore in Firebase.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin for server-side auth, Firestore writes, and Storage uploads.
# You can use FIREBASE_SERVICE_ACCOUNT_KEY or the split client email/private key vars.
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_SERVICE_ACCOUNT_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Dedicated GCS bucket for canonical PDF originals and exact single-page page assets.
# Required in production. Uses Google Application Default Credentials/service account identity.
GCS_PDF_ASSETS_BUCKET=chandra-f6e13-pdf-page-assets

# Cloud SQL PostgreSQL stores app data plus permanent searchable PDF OCR/page/problem metadata.
# DATABASE_URL is also supported; use one of these connection URLs at runtime.
# Local dev can use Cloud SQL Auth Proxy on 127.0.0.1:5432 with sslmode=disable.
# Production should use the Cloud SQL private IP/VPC path or a managed connector, never localhost.
DATABASE_URL=
CLOUD_SQL_POSTGRES_URL=
CHANDRA_CLOUD_SQL_POSTGRES_URL=
CLOUD_SQL_POSTGRES_SSL_MODE=
CLOUD_SQL_POSTGRES_POOL_MAX=
# Defaults to false. Set to 1 only for temporary legacy migration/debug sessions.
POSTGRES_FIRESTORE_FALLBACK=
# Local dev helper for npm run dev:all. Defaults to chandra-f6e13:us-central1:chandra-postgres.
CHANDRA_DEV_CLOUD_SQL_PROXY=
CLOUD_SQL_INSTANCE_CONNECTION_NAME=
CLOUD_SQL_PROXY_BIN=
CLOUD_SQL_PROXY_PORT=5432

# Google Document AI OCR for uploaded PDFs stored in Firebase/GCS.
DOCUMENT_AI_PROJECT_ID=
DOCUMENT_AI_LOCATION=us
DOCUMENT_AI_OCR_PROCESSOR_NAME=chandra-ocr
DOCUMENT_AI_OCR_PROCESSOR_ID=5d3fa32c2ebe2a90
DOCUMENT_AI_OCR_TIMEOUT_MS=600000

# Vertex AI embeddings for tutor knowledge retrieval.
# GOOGLE_CLOUD_PROJECT can be omitted when FIREBASE_PROJECT_ID is the same project.
GEMINI_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us
VERTEX_EMBEDDING_MODEL=gemini-embedding-2
VERTEX_EMBEDDING_DIMENSIONS=768

# Teacher dashboard assistant. Local fallback uses Chandra's tool registry without
# requiring a deployed ADK agent. Agent Runtime keeps Chandra as the tool/security gateway.
TEACHER_ASSISTANT_PROVIDER=local-fallback
TEACHER_ASSISTANT_MODEL=gemini-3-flash-preview
GEMINI_AGENT_RUNTIME_RESOURCE=
GEMINI_AGENT_LOCATION=global
CHANDRA_ASSISTANT_TOOL_BASE_URL=http://localhost:3000
CHANDRA_ASSISTANT_TOOL_SHARED_SECRET=

# Optional if Application Default Credentials are not available.
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_APPLICATION_CREDENTIALS_JSON=
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Backend runtime. Set CHANDRA_ENV=production in deployed containers/servers.
CHANDRA_ENV=development
PORT=8000
