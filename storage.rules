rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function classDoc(classId) {
      return firestore.get(/databases/(default)/documents/classes/$(classId));
    }

    function isClassTeacher(classId) {
      // Teachers and editable co-teachers can manage uploaded class source files.
      return isSignedIn()
        && (
          classDoc(classId).data.teacherId == request.auth.uid
          || (
            classDoc(classId).data.coTeachers is map
            && classDoc(classId).data.coTeachers[request.auth.uid] is map
            && classDoc(classId).data.coTeachers[request.auth.uid].role in ["owner", "co-teacher"]
          )
        );
    }

    function uploadSession(classId, materialId) {
      return firestore.get(/databases/(default)/documents/classes/$(classId)/materialUploadSessions/$(materialId));
    }

    function uploadSessionExists(classId, materialId) {
      return firestore.exists(/databases/(default)/documents/classes/$(classId)/materialUploadSessions/$(materialId));
    }

    function hasUploadSession(classId, materialId) {
      return isSignedIn()
        && uploadSessionExists(classId, materialId)
        && uploadSession(classId, materialId).data.teacherId == request.auth.uid
        && uploadSession(classId, materialId).data.expiresAt > request.time;
    }

    match /classes/{classId}/materials/{materialId}/original/{fileName=**} {
      allow read: if isClassTeacher(classId) || hasUploadSession(classId, materialId);
      allow write: if isClassTeacher(classId) || hasUploadSession(classId, materialId);
    }
  }
}
