rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userProfile(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function userProfileExists(uid) {
      return exists(/databases/$(database)/documents/users/$(uid));
    }

    function isTeacher() {
      return isSignedIn()
        && userProfileExists(request.auth.uid)
        && userProfile(request.auth.uid).data.role == "teacher";
    }

    function isStudentInClass(classId) {
      return isSignedIn()
        && userProfileExists(request.auth.uid)
        && userProfile(request.auth.uid).data.role == "student"
        && (
          userProfile(request.auth.uid).data.classId == classId
          || (
            userProfile(request.auth.uid).data.classIds is list
            && userProfile(request.auth.uid).data.classIds.hasAny([classId])
          )
        );
    }

    function isClassTeacher() {
      return isSignedIn()
        && resource.data.teacherId == request.auth.uid;
    }

    function isClassEditor() {
      return isSignedIn()
        && (
          resource.data.teacherId == request.auth.uid
          || (
            resource.data.coTeachers is map
            && resource.data.coTeachers[request.auth.uid] is map
            && resource.data.coTeachers[request.auth.uid].role in ["owner", "co-teacher"]
          )
        );
    }

    function hasClassAccess(permission) {
      return isSignedIn()
        && (
          resource.data.teacherId == request.auth.uid
          || (
            resource.data.coTeachers is map
            && resource.data.coTeachers[request.auth.uid] is map
            && (
              resource.data.coTeachers[request.auth.uid].role in ["owner", "co-teacher"]
              || (
                resource.data.coTeachers[request.auth.uid].role == "viewer"
                && permission in ["viewOverview", "viewRoster", "viewConversations", "viewMaterials"]
              )
              || (
                resource.data.coTeachers[request.auth.uid].role == "ta"
                && resource.data.coTeachers[request.auth.uid].permissions is map
                && resource.data.coTeachers[request.auth.uid].permissions[permission] == true
              )
            )
          )
        );
    }

    function hasTargetClassAccess(classId, permission) {
      return isSignedIn()
        && (
          get(/databases/$(database)/documents/classes/$(classId)).data.teacherId == request.auth.uid
          || (
            get(/databases/$(database)/documents/classes/$(classId)).data.coTeachers is map
            && get(/databases/$(database)/documents/classes/$(classId)).data.coTeachers[request.auth.uid] is map
            && (
              get(/databases/$(database)/documents/classes/$(classId)).data.coTeachers[request.auth.uid].role in ["owner", "co-teacher"]
              || (
                get(/databases/$(database)/documents/classes/$(classId)).data.coTeachers[request.auth.uid].role == "viewer"
                && permission in ["viewOverview", "viewRoster", "viewConversations", "viewMaterials"]
              )
              || (
                get(/databases/$(database)/documents/classes/$(classId)).data.coTeachers[request.auth.uid].role == "ta"
                && get(/databases/$(database)/documents/classes/$(classId)).data.coTeachers[request.auth.uid].permissions is map
                && get(/databases/$(database)/documents/classes/$(classId)).data.coTeachers[request.auth.uid].permissions[permission] == true
              )
            )
          )
        );
    }

    function isTargetClassTeacher(classId) {
      return isSignedIn()
        && (
          get(/databases/$(database)/documents/classes/$(classId)).data.teacherId == request.auth.uid
          || (
            get(/databases/$(database)/documents/classes/$(classId)).data.coTeachers is map
            && get(/databases/$(database)/documents/classes/$(classId)).data.coTeachers[request.auth.uid] is map
            && get(/databases/$(database)/documents/classes/$(classId)).data.coTeachers[request.auth.uid].role in ["owner", "co-teacher"]
          )
        );
    }

    function hasClassId(data) {
      return data.keys().hasAny(["classId"]);
    }

    function hasClassIds(data) {
      return data.keys().hasAny(["classIds"]);
    }

    function validRole(role) {
      return role == "student" || role == "teacher";
    }

    function validProfileClass(data) {
      return (
          !hasClassId(data)
          || (
            data.role == "student"
            && data.classId is string
            && data.classId.size() > 0
            && exists(/databases/$(database)/documents/classes/$(data.classId))
          )
        )
        && (
          !hasClassIds(data)
          || (
            data.role == "student"
            && data.classIds is list
            && data.classIds.size() <= 50
          )
        );
    }

    function validProfileBase(userId, data) {
      return data.keys().hasOnly([
          "uid",
          "email",
          "displayName",
          "role",
          "username",
          "classId",
          "classIds",
          "appearance",
          "themeColor",
          "createdAt"
        ])
        && data.uid == userId
        && data.email is string
        && data.username is string
        && data.username.size() > 0
        && data.displayName is string
        && data.displayName.size() > 0
        && validRole(data.role)
        && validProfileClass(data)
        && validOptionalProfileAppearance(data)
        && validOptionalProfileThemeColor(data);
    }

    function validProfileCreate(userId) {
      return validProfileBase(userId, request.resource.data)
        && request.resource.data.role == "student"
        && !request.resource.data.keys().hasAny(["classId", "classIds"])
        && request.resource.data.createdAt == request.time;
    }

    function validProfileUpdate(userId) {
      return validProfileBase(userId, request.resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "displayName",
          "appearance",
          "themeColor"
        ])
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.username == resource.data.username
        && request.resource.data.role == resource.data.role
        && (
          (
            !request.resource.data.keys().hasAny(["createdAt"])
            && !resource.data.keys().hasAny(["createdAt"])
          )
          || request.resource.data.createdAt == resource.data.createdAt
        );
    }

    function validProfileThemePreferenceUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "appearance",
          "themeColor"
        ])
        && validOptionalProfileAppearance(request.resource.data)
        && validOptionalProfileThemeColor(request.resource.data);
    }

    function validProfileUsernameBackfill(userId) {
      return validProfileBase(userId, request.resource.data)
        && !resource.data.keys().hasAny(["username"])
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["username"])
        && request.resource.data.username == resource.data.email;
    }

    function validOptionalProfileAppearance(data) {
      return !data.keys().hasAny(["appearance"])
        || validAppearance(data.appearance);
    }

    function validOptionalProfileThemeColor(data) {
      return !data.keys().hasAny(["themeColor"])
        || validThemeColor(data.themeColor);
    }

    function validClassCreate() {
      return request.resource.data.keys().hasOnly([
          "name",
          "section",
          "teacherId",
          "teacherName",
          "joinCode",
          "appearance",
          "behaviorTitle",
          "answerPolicy",
          "behaviorInstructions",
          "coTeacherIds",
          "coTeachers",
          "defaultAssignmentContext",
          "modelSettings",
          "notificationSettings",
          "openingMessage",
          "privacySettings",
          "refusalStyle",
          "responseFormat",
          "sourceDefaults",
          "sourceUsage",
          "studentChatEnabled",
          "studentFacingInstructions",
          "tutorAccess",
          "themeColor",
          "createdAt"
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.section is string
        && request.resource.data.section.size() > 0
        && request.resource.data.teacherId == request.auth.uid
        && request.resource.data.teacherName is string
        && request.resource.data.teacherName.size() > 0
        && validJoinCode(request.resource.data)
        && validAppearance(request.resource.data.appearance)
        && validAnswerPolicy(request.resource.data.answerPolicy)
        && request.resource.data.behaviorTitle is string
        && request.resource.data.behaviorInstructions is string
        && validCoTeachers(request.resource.data)
        && request.resource.data.defaultAssignmentContext is string
        && validModelSettings(request.resource.data.modelSettings)
        && validNotificationSettings(request.resource.data.notificationSettings)
        && request.resource.data.openingMessage is string
        && validPrivacySettings(request.resource.data.privacySettings)
        && request.resource.data.refusalStyle is string
        && validResponseFormat(request.resource.data.responseFormat)
        && validSourceDefaults(request.resource.data.sourceDefaults)
        && validSourceUsage(request.resource.data.sourceUsage)
        && request.resource.data.studentChatEnabled is bool
        && request.resource.data.studentFacingInstructions is string
        && validTutorAccess(request.resource.data.tutorAccess)
        && validThemeColor(request.resource.data.themeColor)
        && request.resource.data.createdAt == request.time;
    }

    function validClassUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "name",
            "section",
            "joinCode",
            "appearance",
            "answerPolicy",
            "behaviorTitle",
            "behaviorInstructions",
            "coTeacherIds",
            "coTeachers",
            "defaultAssignmentContext",
            "modelSettings",
            "notificationSettings",
            "openingMessage",
            "privacySettings",
            "refusalStyle",
            "responseFormat",
            "sourceUsage",
            "sourceDefaults",
            "studentChatEnabled",
            "studentFacingInstructions",
            "tutorAccess",
            "themeColor"
          ])
        && request.resource.data.teacherId == resource.data.teacherId
        && stableClassTeacherName()
        && stableClassCreatedAt()
        && validJoinCode(request.resource.data)
        && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(["joinCode"])
          || validClassSettings(request.resource.data)
        );
    }

    function validClassSettings(data) {
      return data.keys().hasAll([
          "name",
          "section",
          "appearance",
          "answerPolicy",
          "behaviorTitle",
          "behaviorInstructions",
          "defaultAssignmentContext",
          "modelSettings",
          "notificationSettings",
          "openingMessage",
          "privacySettings",
          "refusalStyle",
          "responseFormat",
          "sourceDefaults",
          "sourceUsage",
          "studentChatEnabled",
          "studentFacingInstructions",
          "tutorAccess",
          "themeColor"
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.section is string
        && request.resource.data.section.size() > 0
        && validAppearance(request.resource.data.appearance)
        && validAnswerPolicy(request.resource.data.answerPolicy)
        && request.resource.data.behaviorTitle is string
        && validOptionalCoTeachers(request.resource.data)
        && request.resource.data.defaultAssignmentContext is string
        && validModelSettings(request.resource.data.modelSettings)
        && validNotificationSettings(request.resource.data.notificationSettings)
        && request.resource.data.behaviorInstructions is string
        && request.resource.data.openingMessage is string
        && validPrivacySettings(request.resource.data.privacySettings)
        && request.resource.data.refusalStyle is string
        && validResponseFormat(request.resource.data.responseFormat)
        && validSourceDefaults(request.resource.data.sourceDefaults)
        && validSourceUsage(request.resource.data.sourceUsage)
        && request.resource.data.studentChatEnabled is bool
        && request.resource.data.studentFacingInstructions is string
        && validTutorAccess(request.resource.data.tutorAccess)
        && validThemeColor(request.resource.data.themeColor);
    }

    function validThemeColor(themeColor) {
      return themeColor is string
        && themeColor in ["purple", "indigo", "blue", "teal", "emerald", "amber", "rose"];
    }

    function validAppearance(appearance) {
      return appearance is string
        && appearance in ["light", "dark"];
    }

    function validAnswerPolicy(answerPolicy) {
      return answerPolicy is map
        && answerPolicy.keys().hasOnly([
          "doNotGiveFinalAnswers",
          "requireStudentAttemptFirst",
          "askGuidingQuestionBeforeExplaining",
          "allowWorkedExamples",
          "refuseAnswerOnlyRequests"
        ])
        && answerPolicy.doNotGiveFinalAnswers is bool
        && answerPolicy.requireStudentAttemptFirst is bool
        && answerPolicy.askGuidingQuestionBeforeExplaining is bool
        && answerPolicy.allowWorkedExamples is bool
        && answerPolicy.refuseAnswerOnlyRequests is bool;
    }

    function validSourceUsage(sourceUsage) {
      return sourceUsage is map
        && sourceUsage.keys().hasOnly([
          "useClassMaterialsFirst",
          "citeSourcePages",
          "askClarificationIfSourceUnclear",
          "preferredSourceType",
          "quoteSourcePassages"
        ])
        && sourceUsage.useClassMaterialsFirst is bool
        && sourceUsage.citeSourcePages is bool
        && sourceUsage.askClarificationIfSourceUnclear is bool
        && sourceUsage.preferredSourceType is string
        && sourceUsage.preferredSourceType.size() > 0
        && sourceUsage.quoteSourcePassages is bool;
    }

    function validCoTeachers(data) {
      return data.coTeacherIds is list
        && data.coTeacherIds.size() <= 25
        && data.coTeachers is map
        && data.coTeachers.keys().size() <= 25;
    }

    function validOptionalCoTeachers(data) {
      return (
          !data.keys().hasAny(["coTeacherIds"])
          && !data.keys().hasAny(["coTeachers"])
        )
        || (
          data.keys().hasAll(["coTeacherIds", "coTeachers"])
          && validCoTeachers(data)
        );
    }

    function validPrivacySettings(privacySettings) {
      return privacySettings is map
        && privacySettings.keys().hasOnly(["conversationRetention"])
        && privacySettings.conversationRetention in ["forever", "30-days", "90-days", "1-year"];
    }

    function validSourceDefaults(sourceDefaults) {
      return sourceDefaults is map
        && sourceDefaults.keys().hasOnly([
          "activeForStudents",
          "teacherOnly",
          "citationsRequired",
          "priority",
          "answerKeysTeacherReviewOnly",
          "sourceTypePreferences"
        ])
        && sourceDefaults.activeForStudents is bool
        && sourceDefaults.teacherOnly is bool
        && sourceDefaults.citationsRequired is bool
        && sourceDefaults.priority in ["primary", "normal", "low"]
        && sourceDefaults.answerKeysTeacherReviewOnly is bool
        && validSourceTypePreferences(sourceDefaults.sourceTypePreferences);
    }

    function validSourceTypePreferences(sourceTypePreferences) {
      return sourceTypePreferences is map
        && sourceTypePreferences.keys().hasOnly([
          "Assignment",
          "Textbook",
          "Notes",
          "Worked Example",
          "Rubric",
          "Answer Key"
        ])
        && sourceTypePreferences.Assignment in ["inherit", "student-visible", "teacher-review", "hidden"]
        && sourceTypePreferences.Textbook in ["inherit", "student-visible", "teacher-review", "hidden"]
        && sourceTypePreferences.Notes in ["inherit", "student-visible", "teacher-review", "hidden"]
        && sourceTypePreferences["Worked Example"] in ["inherit", "student-visible", "teacher-review", "hidden"]
        && sourceTypePreferences.Rubric in ["inherit", "student-visible", "teacher-review", "hidden"]
        && sourceTypePreferences["Answer Key"] in ["inherit", "student-visible", "teacher-review", "hidden"];
    }

    function validNotificationSettings(notificationSettings) {
      return notificationSettings is map
        && notificationSettings.keys().hasOnly([
          "weeklyDigest",
          "followUpReminders",
          "newStudentJoinedClass"
        ])
        && notificationSettings.weeklyDigest is bool
        && notificationSettings.followUpReminders is bool
        && notificationSettings.newStudentJoinedClass is bool;
    }

    function validModelSettings(modelSettings) {
      return modelSettings is map
        && modelSettings.keys().hasOnly([
          "modelId",
          "reasoningEffort",
          "creativity",
          "verbose",
          "requestLimits",
          "tokenLimits"
        ])
        && modelSettings.modelId is string
        && modelSettings.modelId.size() > 0
        && modelSettings.reasoningEffort is string
        && modelSettings.reasoningEffort in ["low", "medium", "high"]
        && modelSettings.creativity is number
        && modelSettings.creativity >= 0
        && modelSettings.creativity <= 100
        && modelSettings.verbose is string
        && modelSettings.verbose in ["brief", "standard", "detailed", "veryDetailed"]
        && validAiRequestLimits(modelSettings.requestLimits)
        && validAiTokenLimits(modelSettings.tokenLimits);
    }

    function validAiRequestLimits(requestLimits) {
      return requestLimits is map
        && requestLimits.keys().hasOnly([
          "perStudentDaily",
          "perStudentWeekly",
          "perClassDaily",
          "teacherPreviewDaily"
        ])
        && requestLimits.perStudentDaily is number
        && requestLimits.perStudentDaily >= 1
        && requestLimits.perStudentDaily <= 10000
        && requestLimits.perStudentWeekly is number
        && requestLimits.perStudentWeekly >= 1
        && requestLimits.perStudentWeekly <= 100000
        && requestLimits.perClassDaily is number
        && requestLimits.perClassDaily >= 1
        && requestLimits.perClassDaily <= 500000
        && (requestLimits.teacherPreviewDaily == null
          || (
            requestLimits.teacherPreviewDaily is number
            && requestLimits.teacherPreviewDaily >= 1
            && requestLimits.teacherPreviewDaily <= 10000
          ));
    }

    function validAiTokenLimits(tokenLimits) {
      return tokenLimits is map
        && tokenLimits.keys().hasOnly([
          "perHour",
          "perDay",
          "perWeek"
        ])
        && tokenLimits.perHour is number
        && tokenLimits.perHour >= 1000
        && tokenLimits.perHour <= 1000000
        && tokenLimits.perDay is number
        && tokenLimits.perDay >= 1000
        && tokenLimits.perDay <= 5000000
        && tokenLimits.perWeek is number
        && tokenLimits.perWeek >= 1000
        && tokenLimits.perWeek <= 20000000;
    }

    function validTutorAccess(tutorAccess) {
      return tutorAccess is map
        && tutorAccess.keys().hasOnly(["enabled"])
        && tutorAccess.enabled is bool;
    }

    function validResponseFormat(responseFormat) {
      return responseFormat is map
        && responseFormat.keys().hasOnly([
          "oneStepAtATime",
          "endWithCheckQuestion",
          "simpleWording",
          "exampleFrequency",
          "mathNotation"
        ])
        && responseFormat.oneStepAtATime is bool
        && responseFormat.endWithCheckQuestion is bool
        && responseFormat.simpleWording is bool
        && responseFormat.exampleFrequency is string
        && responseFormat.exampleFrequency in ["rarely", "whenHelpful", "often"]
        && responseFormat.mathNotation is string
        && responseFormat.mathNotation in ["plain", "balanced", "symbolic"];
    }

    function validJoinCode(data) {
      return !data.keys().hasAny(["joinCode"])
        || (
          data.joinCode is string
          && data.joinCode.size() == 6
          && data.joinCode.matches("^[A-Z]{6}$")
        );
    }

    function stableClassTeacherName() {
      return (
          !request.resource.data.keys().hasAny(["teacherName"])
          && !resource.data.keys().hasAny(["teacherName"])
        )
        || request.resource.data.teacherName == resource.data.teacherName;
    }

    function stableClassCreatedAt() {
      return (
          !request.resource.data.keys().hasAny(["createdAt"])
          && !resource.data.keys().hasAny(["createdAt"])
        )
        || request.resource.data.createdAt == resource.data.createdAt;
    }

    function validRosterStudent() {
      return request.resource.data.keys().hasOnly(["email", "displayName", "addedAt"])
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0
        && request.resource.data.addedAt == request.time;
    }

    function validPresence(userId) {
      return request.resource.data.keys().hasOnly([
          "uid",
          "email",
          "displayName",
          "role",
          "classId",
          "online",
          "lastSeenAt",
          "updatedAt"
        ])
        && request.resource.data.uid == userId
        && request.resource.data.email is string
        && request.resource.data.displayName is string
        && request.resource.data.role is string
        && request.resource.data.classId is string
        && request.resource.data.online is bool
        && request.resource.data.lastSeenAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function isStudentVisibleMaterial(data) {
      return data.status == "ready"
        && data.activeForStudents != false
        && data.studentVisible != false
        && data.teacherOnly != true
        && !(data.visibility in ["teacher-only", "hidden"])
        && data.private != true;
    }

    function isStudentVisibleMaterialDocument(classId, materialId) {
      return isStudentVisibleMaterial(
        get(/databases/$(database)/documents/classes/$(classId)/materials/$(materialId)).data
      );
    }

    match /users/{userId} {
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && validProfileCreate(userId);
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && (
          validProfileUpdate(userId)
          || validProfileThemePreferenceUpdate()
          || validProfileUsernameBackfill(userId)
        );
    }

    match /userPresence/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create, update: if isSignedIn()
        && request.auth.uid == userId
        && validPresence(userId);
      allow delete: if false;
    }

    match /teacherInvites/{inviteId} {
      allow read, write: if false;
    }

    match /auditLogs/{auditLogId} {
      allow read, write: if false;
    }

    match /securityEvents/{securityEventId} {
      allow read, write: if false;
    }

    match /chatErrorReferences/{errorId} {
      allow read, write: if false;
    }

    match /rateLimits/{rateLimitId} {
      allow read, write: if false;
    }

    match /abuseLockouts/{abuseLockoutId} {
      allow read, write: if false;
    }

    match /classes/{classId} {
      allow create: if isTeacher()
        && validClassCreate();
      allow get: if isClassTeacher() || hasClassAccess("viewOverview");
      allow list: if isSignedIn()
        && resource.data.teacherId == request.auth.uid;
      allow list: if isSignedIn()
        && request.auth.uid in resource.data.coTeacherIds;
      allow update: if isClassEditor() && validClassUpdate();
      allow delete: if isClassTeacher();

      match /students/{studentId} {
        allow read: if hasTargetClassAccess(classId, "viewRoster");
        allow create, update: if hasTargetClassAccess(classId, "manageRoster") && validRosterStudent();
        allow delete: if hasTargetClassAccess(classId, "manageRoster");
      }

      match /materials/{materialId} {
        allow read: if hasTargetClassAccess(classId, "viewMaterials")
          || (isStudentInClass(classId) && isStudentVisibleMaterial(resource.data));
        allow write: if hasTargetClassAccess(classId, "manageMaterials");

        match /chunks/{chunkId} {
          allow read: if hasTargetClassAccess(classId, "viewMaterials")
            || (isStudentInClass(classId) && isStudentVisibleMaterialDocument(classId, materialId));
          allow write: if hasTargetClassAccess(classId, "manageMaterials");
        }
      }

      match /materialJobs/{jobId} {
        allow read: if hasTargetClassAccess(classId, "viewMaterials");
        allow write: if false;
      }

      match /materialUploadSessions/{materialId} {
        allow read: if hasTargetClassAccess(classId, "manageMaterials")
          && resource.data.teacherId == request.auth.uid;
        allow write: if false;
      }

      match /studentLearningProfiles/{profileId} {
        allow read: if hasTargetClassAccess(classId, "manageLearningProfiles");
        allow write: if false;

        match /revisions/{revisionId} {
          allow read: if hasTargetClassAccess(classId, "manageLearningProfiles");
          allow write: if false;
        }
      }

      match /conversationReviews/{conversationId} {
        allow read: if hasTargetClassAccess(classId, "reviewConversations");
        allow write: if false;
      }

      match /studentFeedback/{feedbackId} {
        allow read: if hasTargetClassAccess(classId, "reviewConversations")
          || (
            isStudentInClass(classId)
            && resource.data.studentId == request.auth.uid
          );
        allow write: if false;
      }

      match /conversations/{conversationId} {
        allow get, list: if hasTargetClassAccess(classId, "viewConversations")
          || (
            isStudentInClass(classId)
            && resource.data.studentId == request.auth.uid
          );
        allow write: if false;

        match /messages/{messageId} {
          allow get, list: if hasTargetClassAccess(classId, "viewConversations")
            || (
              isStudentInClass(classId)
              && get(/databases/$(database)/documents/classes/$(classId)/conversations/$(conversationId)).data.studentId == request.auth.uid
            );
          allow write: if false;
        }
      }
    }
  }
}
